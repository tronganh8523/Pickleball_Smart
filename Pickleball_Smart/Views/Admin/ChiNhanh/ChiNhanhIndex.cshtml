@model IEnumerable<Pickleball_Smart.Models.ChiNhanh>

@{
    ViewData["Title"] = "Quản Lý Chi Nhánh";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3 mb-0 text-dark">
                <i class="fas fa-building"></i> Quản Lý Chi Nhánh
            </h1>
        </div>
        <div class="col-md-4 text-right">
            <a asp-action="ChiNhanhCreate" class="btn btn-primary">
                <i class="fas fa-plus"></i> Thêm Chi Nhánh Mới
            </a>
        </div>
    </div>

    <!-- Thông báo -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Danh sách Chi Nhánh -->
    <div class="card shadow mb-4">
        <div class="card-header bg-primary text-white">
            <h6 class="m-0 font-weight-bold">Danh Sách Chi Nhánh</h6>
        </div>
        <div class="card-body">
            @if (Model.Count() == 0)
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> Chưa có chi nhánh nào. Hãy thêm chi nhánh mới!
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Tên Chi Nhánh</th>
                                <th>Địa Chỉ</th>
                                <th>Số Điện Thoại</th>
                                <th style="width: 150px;">Hành Động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>@Html.DisplayFor(modelItem => item.TenChiNhanh)</strong></td>
                                    <td>@Html.DisplayFor(modelItem => item.DiaChi)</td>
                                    <td>@Html.DisplayFor(modelItem => item.SDT_LienHe)</td>
                                    <td>
                                        <a asp-action="ChiNhanhEdit" asp-route-id="@item.ChiNhanhID" class="btn btn-sm btn-warning" title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i> Sửa
                                        </a>
                                        <a asp-action="ChiNhanhDelete" asp-route-id="@item.ChiNhanhID" class="btn btn-sm btn-danger" title="Xóa">
                                            <i class="fas fa-trash"></i> Xóa
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Nút quay lại -->
    <div class="row">
        <div class="col-md-12">
            <a asp-action="Dashboard" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Quay Lại
            </a>
        </div>
    </div>
</div>

<style>
    .btn-group {
        display: flex;
        gap: 5px;
    }
</style>
