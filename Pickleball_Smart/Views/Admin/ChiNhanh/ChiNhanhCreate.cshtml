@model Pickleball_Smart.Models.ChiNhanh

@{
    ViewData["Title"] = "Thêm Chi Nhánh";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="h3 mb-4 text-dark">
                Thêm Chi Nhánh Mới
            </h1>

            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white">
                    <h6 class="m-0 font-weight-bold">Nhập Thông Tin Chi Nhánh</h6>
                </div>
                <div class="card-body">
                    <form asp-action="ChiNhanhCreate" method="post">

                        <div class="form-group mb-3">
                            <label for="TenChiNhanh" class="form-label"><strong>Tên Chi Nhánh <span class="text-danger">*</span></strong></label>
                            <input type="text" class="form-control" 
                                   id="TenChiNhanh" asp-for="TenChiNhanh" placeholder="Nhập tên chi nhánh" required>
                            <span asp-validation-for="TenChiNhanh" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label for="DiaChi" class="form-label"><strong>Địa Chỉ</strong></label>
                            <input type="text" class="form-control" id="DiaChi" asp-for="DiaChi" placeholder="Nhập địa chỉ chi nhánh">
                            <span asp-validation-for="DiaChi" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label for="SDT_LienHe" class="form-label"><strong>Số Điện Thoại Liên Hệ <span class="text-danger">*</span></strong></label>
                            <input type="tel" class="form-control" id="SDT_LienHe" asp-for="SDT_LienHe" placeholder="Nhập số điện thoại" required>
                            <span asp-validation-for="SDT_LienHe" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <button type="submit" class="btn btn-primary btn-block">
                                    <i class="fas fa-save"></i> Thêm Chi Nhánh
                                </button>
                            </div>
                            <div class="col-md-6">
                                <a asp-action="ChiNhanhIndex" class="btn btn-secondary btn-block">
                                    <i class="fas fa-times"></i> Hủy
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
