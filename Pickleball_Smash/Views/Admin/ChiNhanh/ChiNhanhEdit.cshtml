@model Pickleball_Smash.Models.ChiNhanh

@{
    ViewData["Title"] = "Chỉnh Sửa Chi Nhánh";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="h3 mb-4 text-dark">Chỉnh Sửa Chi Nhánh</h1>
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white"><h6 class="m-0">Thông Tin Chi Nhánh</h6></div>
                <div class="card-body">
                    <form asp-controller="Admin" asp-action="ChiNhanhEdit" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="ChiNhanhID" />

                        <div class="mb-3">
                            <label asp-for="TenChiNhanh" class="form-label"></label>
                            <input asp-for="TenChiNhanh" class="form-control" />
                            <span asp-validation-for="TenChiNhanh" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DiaChi" class="form-label"></label>
                            <input asp-for="DiaChi" class="form-control" />
                            <span asp-validation-for="DiaChi" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SDT_LienHe" class="form-label"></label>
                            <input asp-for="SDT_LienHe" class="form-control" />
                            <span asp-validation-for="SDT_LienHe" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary">Lưu</button>
                        <a asp-controller="Admin" asp-action="ChiNhanhIndex" class="btn btn-secondary">Hủy</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

