@model Pickleball_Smash.Models.ChiNhanh

@{
    ViewData["Title"] = "Xóa Chi Nhánh";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h1 class="h3 mb-4 text-dark">Xóa Chi Nhánh</h1>
            <div class="card shadow border-danger mb-4">
                <div class="card-header bg-danger text-white"><h6 class="m-0">Xác Nhận Xóa</h6></div>
                <div class="card-body">
                    <p>Bạn có chắc muốn xóa chi nhánh <strong>@Model.TenChiNhanh</strong>?</p>
                    <form asp-controller="Admin" asp-action="ChiNhanhDelete" method="post">
                        <input type="hidden" asp-for="ChiNhanhID" />
                        <button type="submit" class="btn btn-danger">Xóa</button>
                        <a asp-controller="Admin" asp-action="ChiNhanhIndex" class="btn btn-secondary">Hủy</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

