@model IEnumerable<Pickleball_Smash.Models.ChiNhanh>

@{
    ViewData["Title"] = "Quản Lý Chi Nhánh";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3 mb-0 text-dark"><i class="fas fa-building"></i> Danh Sách Chi Nhánh</h1>
        </div>
        <div class="col-md-4 text-right">
            <a asp-controller="AdminChiNhanh" asp-action="ChiNhanhCreate" class="btn btn-primary">
                <i class="fas fa-plus"></i> Thêm Chi Nhánh Mới
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Tên</th>
                            <th>Địa Chỉ</th>
                            <th>Số Điện Thoại</th>
                            <th>Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.TenChiNhanh</td>
                                <td>@item.DiaChi</td>
                                <td>@item.SDT_LienHe</td>
                                <td>
                                    <a asp-controller="AdminChiNhanh" asp-action="ChiNhanhEdit" asp-route-id="@item.ChiNhanhID" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                                    <a asp-controller="AdminChiNhanh" asp-action="ChiNhanhDelete" asp-route-id="@item.ChiNhanhID" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</style>

