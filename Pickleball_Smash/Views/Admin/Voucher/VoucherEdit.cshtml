@model Pickleball_Smash.Models.Voucher

@{
    ViewData["Title"] = "Chỉnh Sửa Voucher";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="h3 mb-4 text-dark">Chỉnh Sửa Voucher</h1>
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white"><h6 class="m-0">Thông Tin Voucher</h6></div>
                <div class="card-body">
                    <form asp-controller="AdminVoucher" asp-action="Edit" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="VoucherID" />

                        <div class="mb-3">
                            <label asp-for="MaVoucher" class="form-label">Mã Voucher</label>
                            <input asp-for="MaVoucher" class="form-control" />
                            <span asp-validation-for="MaVoucher" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MoTa" class="form-label">Mô Tả</label>
                            <input asp-for="MoTa" class="form-control" />
                            <span asp-validation-for="MoTa" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LoaiGiamGia" class="form-label">Loại Giảm Giá</label>
                            <select asp-for="LoaiGiamGia" class="form-select" id="LoaiGiamGia">
                                <option value="">-- chọn --</option>
                                <option value="%">%</option>
                                <option value="VNĐ">VNĐ</option>
                            </select>
                            <span asp-validation-for="LoaiGiamGia" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="GiaTriGiam" class="form-label">Giá Trị Giảm</label>
                            <input asp-for="GiaTriGiam" class="form-control" id="GiaTriGiam" type="number" step="0.01" min="0.01" />
                            <small id="giaTriGiamHint" class="form-text text-muted">Chọn loại giảm giá để áp dụng điều kiện nhập.</small>
                            <span asp-validation-for="GiaTriGiam" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="GiamToiDa" class="form-label">Giảm Tối Đa</label>
                            <input asp-for="GiamToiDa" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="GiamToiDa" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="GiaTriDonToiThieu" class="form-label">Giá Trị Đơn Tối Thiểu</label>
                            <input asp-for="GiaTriDonToiThieu" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="GiaTriDonToiThieu" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NgayBatDau" class="form-label">Ngày Bắt Đầu</label>
                            <input asp-for="NgayBatDau" class="form-control" type="datetime-local" />
                            <span asp-validation-for="NgayBatDau" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NgayKetThuc" class="form-label">Ngày Kết Thúc</label>
                            <input asp-for="NgayKetThuc" class="form-control" type="datetime-local" />
                            <span asp-validation-for="NgayKetThuc" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SoLuongToiDa" class="form-label">Số Lượng Tối Đa</label>
                            <input asp-for="SoLuongToiDa" class="form-control" type="number" />
                            <span asp-validation-for="SoLuongToiDa" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SoLuongDaDung" class="form-label">Số Lượng Đã Dùng</label>
                            <input asp-for="SoLuongDaDung" class="form-control" type="number" />
                            <span asp-validation-for="SoLuongDaDung" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TrangThai" class="form-label">Trạng Thái</label>
                            <input asp-for="TrangThai" class="form-control" readonly />
                            <small class="form-text text-muted">Tự động cập nhật theo khoảng ngày bắt đầu - ngày kết thúc.</small>
                            <span asp-validation-for="TrangThai" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary">Lưu</button>
                        <a asp-controller="AdminVoucher" asp-action="Index" class="btn btn-secondary">Hủy</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const loaiSelect = document.getElementById('LoaiGiamGia');
            const giaTriInput = document.getElementById('GiaTriGiam');
            const hint = document.getElementById('giaTriGiamHint');

            function applyDiscountRule() {
                const loai = loaiSelect.value;
                giaTriInput.removeAttribute('max');

                if (loai === '%') {
                    giaTriInput.min = '1';
                    giaTriInput.max = '100';
                    hint.textContent = 'Loại %: Giá trị giảm từ 1 đến 100.';
                    return;
                }

                if (loai === 'VNĐ') {
                    giaTriInput.min = '0.01';
                    hint.textContent = 'Loại VNĐ: Giá trị giảm phải lớn hơn 0.';
                    return;
                }

                giaTriInput.min = '0.01';
                hint.textContent = 'Chọn loại giảm giá để áp dụng điều kiện nhập.';
            }

            loaiSelect.addEventListener('change', applyDiscountRule);
            applyDiscountRule();
        })();
    </script>
}
