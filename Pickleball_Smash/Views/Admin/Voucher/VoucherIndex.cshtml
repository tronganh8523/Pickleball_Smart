@model IEnumerable<Pickleball_Smash.Models.Voucher>

@{
    ViewData["Title"] = "Quản Lý Voucher";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3 mb-0 text-dark"><i class="fas fa-ticket-alt"></i> Danh Sách Voucher</h1>
        </div>
        <div class="col-md-4 text-right">
            <a asp-controller="AdminVoucher" asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Thêm Voucher Mới
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Mã</th>
                            <th>Loại</th>
                            <th>Giảm</th>
                            <th>Số Lượng</th>
                            <th>Bắt Đầu</th>
                            <th>Kết Thúc</th>
                            <th>Trạng Thái</th>
                            <th>Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MaVoucher</td>
                                <td>@item.LoaiGiamGia</td>
                                <td>@(item.GiaTriGiam?.ToString("F0") ?? "")</td>
                                <td>@item.SoLuongDaDung / @item.SoLuongToiDa</td>
                                <td>@item.NgayBatDau?.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.NgayKetThuc?.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.TrangThai</td>
                                <td>
                                    <a asp-controller="AdminVoucher" asp-action="Edit" asp-route-id="@item.VoucherID" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                                    <a asp-controller="AdminVoucher" asp-action="Delete" asp-route-id="@item.VoucherID" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
