@model Pickleball_Smash.Models.Voucher

@{
    ViewData["Title"] = "Xóa Voucher";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h1 class="h3 mb-4 text-dark">Xóa Voucher</h1>
            <div class="card shadow border-danger mb-4">
                <div class="card-header bg-danger text-white"><h6 class="m-0">Xác Nhận Xóa</h6></div>
                <div class="card-body">
                    <p>Bạn có chắc muốn xóa voucher <strong>@Model.MaVoucher</strong>?</p>
                    <form asp-controller="AdminVoucher" asp-action="Delete" method="post">
                        <input type="hidden" asp-for="VoucherID" />
                        <button type="submit" class="btn btn-danger">Xóa</button>
                        <a asp-controller="AdminVoucher" asp-action="Index" class="btn btn-secondary">Hủy</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
