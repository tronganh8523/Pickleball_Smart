@model IEnumerable<Pickleball_Smash.Models.SanPickleball>

@{
    ViewData["Title"] = "Quản Lý Sân Pickleball";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3 mb-0 text-dark"><i class="fas fa-store"></i> Danh Sách Sân Pickleball</h1>
        </div>
        <div class="col-md-4 text-right">
            <a asp-controller="AdminSan" asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Thêm Sân Mới
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Tên</th>
                            <th>Chi Nhánh</th>
                            <th>Loại Sân</th>
                            <th>Giá Cơ Bản</th>
                            <th>Trạng Thái</th>
                            <th>Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var item in Model)
                        {
                            <tr>
                                <td>@item.TenSan</td>
                                <td>@item.ChiNhanh?.TenChiNhanh</td>
                                <td>@item.LoaiSan</td>
                                <td>@(item.GiaCoBan?.ToString("F0") ?? "")</td>
                                <td>@item.TrangThai</td>
                                <td>
                                    <a asp-controller="AdminSan" asp-action="Edit" asp-route-id="@item.SanID" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                                    <a asp-controller="AdminSan" asp-action="Delete" asp-route-id="@item.SanID" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
