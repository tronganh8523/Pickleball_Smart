@model Pickleball_Smash.Models.SanPickleball

@{
    ViewData["Title"] = "Thêm Sân Pickleball";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="h3 mb-4 text-dark">Thêm Sân Pickleball</h1>
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white"><h6 class="m-0">Thông Tin Sân</h6></div>
                <div class="card-body">
                    <form asp-controller="AdminSan" asp-action="Create" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="ChiNhanhID" class="form-label">Chi Nhánh</label>
                            <select asp-for="ChiNhanhID" class="form-select" asp-items="@(new SelectList(ViewBag.ChiNhanhs, "ChiNhanhID", "TenChiNhanh"))">
                                <option value="">-- chọn --</option>
                            </select>
                            <span asp-validation-for="ChiNhanhID" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TenSan" class="form-label">Tên Sân</label>
                            <input asp-for="TenSan" class="form-control" />
                            <span asp-validation-for="TenSan" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LoaiSan" class="form-label">Loại Sân</label>
                            <select asp-for="LoaiSan" class="form-select">
                                <option value="">-- chọn --</option>
                                <option value="Trong nhà">Trong nhà</option>
                                <option value="Ngoài trời">Ngoài trời</option>
                            </select>
                            <span asp-validation-for="LoaiSan" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MoTa" class="form-label">Mô Tả</label>
                            <textarea asp-for="MoTa" class="form-control"></textarea>
                            <span asp-validation-for="MoTa" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="GiaCoBan" class="form-label">Giá Cơ Bản</label>
                            <input asp-for="GiaCoBan" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="GiaCoBan" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TrangThai" class="form-label">Trạng Thái</label>
                            <select asp-for="TrangThai" class="form-select">
                                <option value="">-- chọn --</option>
                                <option value="Mở">Mở</option>
                                <option value="Đóng">Đóng</option>
                            </select>
                            <span asp-validation-for="TrangThai" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary">Lưu</button>
                        <a asp-controller="AdminSan" asp-action="Index" class="btn btn-secondary">Hủy</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
